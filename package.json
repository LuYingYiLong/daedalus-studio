{
  "name": "daedalus-studio",
  "version": "1.0.0",
  "description": "daedalus-studio",
  "license": "MIT",
  "author": "LuYingYiLong",
  "main": "out/main/index.js",
  "config": {
    "electron_mirror": "https://npmmirror.com/mirrors/electron/"
  },
  "scripts": {
    "dev": "node scripts/electron-vite.cjs dev",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node scripts/electron-vite.cjs build",
    "pack": "npm run pack:win",
    "pack:win": "npm run build && electron-builder --win --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dist": "npm run build:win",
    "preview": "node scripts/electron-vite.cjs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "antd": "^6.5.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "ws": "^8.21.0"
  }
}
